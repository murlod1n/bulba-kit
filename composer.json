{
    "name": "nktlksvch/bulba-kit",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Nktlksvch\\BulbaKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nktlksvch\\BulbaKit\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Nikita Alekseyevich",
            "email": "nikitamurdloin@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5.0",
        "laravel/prompts": "^0.3.18",
        "illuminate/support": "^13.16.1",
        "illuminate/filesystem": "^13.16.1"
    },
    "require-dev": {
        "orchestra/testbench": "^v11.1.0",
        "phpunit/phpunit": "^11.0 || ^12.0 || ^13.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nktlksvch\\BulbaKit\\Providers\\BulbaKitServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
